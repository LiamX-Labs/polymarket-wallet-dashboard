# ==========================================
# Backend Server Configuration
# ==========================================
# Copy this file to .env and configure for local development

# Server Port
PORT=3001

# --- Local development (SQLite) ---
TRACKER_DB_PATH=../data/tracker.sqlite3
DASHBOARD_DB_PATH=../data/dashboard.db

# --- Vercel / Production (PostgreSQL) ---
# When POSTGRES_URL is set, SQLite paths are ignored.
# Vercel Postgres injects these automatically when you add a Postgres store.
# POSTGRES_URL=postgres://...
# DATABASE_URL=postgres://...

# CORS (set to your Vercel URL in production)
CORS_ORIGIN=*

# Sync interval in milliseconds (local dev only; Vercel uses on-demand sync)
SYNC_INTERVAL_MS=30000

# Environment
NODE_ENV=development
