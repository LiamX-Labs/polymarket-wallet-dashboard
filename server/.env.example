# ==========================================
# Backend Server Configuration
# ==========================================
# Copy this file to .env and configure for local development

# Server Port
PORT=3001

# Database Paths
# Local Development:
TRACKER_DB_PATH=../data/tracker.sqlite3
DASHBOARD_DB_PATH=../data/dashboard.db

# Production (Render):
# TRACKER_DB_PATH=/var/data/tracker.sqlite3
# DASHBOARD_DB_PATH=/var/data/dashboard.db

# Environment
NODE_ENV=development
