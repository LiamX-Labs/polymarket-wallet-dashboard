# ==========================================
# Frontend Client Configuration
# ==========================================
# Copy this file to .env and configure based on your environment

# API URL - Backend server URL
#
# LOCAL DEVELOPMENT (leave empty to use Vite proxy):
VITE_API_URL=
#
# VERCEL (leave empty — API is served from same domain at /api):
# VITE_API_URL=
#
# RENDER / separate API host:
# VITE_API_URL=https://polymarket-dashboard-api.onrender.com
#
# The default proxy target is http://localhost:10000 (see vite.config.ts)
