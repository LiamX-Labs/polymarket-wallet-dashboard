# ==========================================
# Polymarket Tracker Configuration
# ==========================================
# Copy this file to .env and configure for local development
# For production deployment to Render, these are set in render.yaml

# Telegram Bot Configuration (Optional - only if TRACKER_DRY_RUN=false)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TRACKER_TELEGRAM_CHAT_ID=your_chat_id_here
ALLOWED_USER_IDS=your_user_id_here

# Optional: PolygonScan API Key for enhanced data
POLYGONSCAN_API_KEY=

# Tracker Polling Settings
TRACKER_POLL_INTERVAL_SECONDS=15
TRACKER_TRIGGER_TOLERANCE_SECONDS=20

# Database Path
# Local: Full path to your project's data directory
# Render: /var/data/tracker.sqlite3
TRACKER_DATABASE_PATH=./data/tracker.sqlite3

# PostgreSQL (Render Postgres / Neon) — required on Render; mirrors summary to cloud
# POSTGRES_URL=postgres://...

# Low memory mode (auto-enabled on Render) — reduces tracker parallelism
# LOW_MEMORY_MODE=true
# TRACKER_MAX_WORKERS=2
# TRACKER_MAX_CONCURRENT_ANALYSES=1

# Daily Report Settings
TRACKER_DAILY_REPORT_HOUR_UTC=23

# Dry Run Mode
# true = No Telegram messages sent (prints to console only)
# false = Sends Telegram messages
TRACKER_DRY_RUN=true

# API Endpoints (Usually don't need to change)
GAMMA_API_BASE_URL=https://gamma-api.polymarket.com
CLOB_API_BASE_URL=https://clob.polymarket.com
